# Cloudinary Configuration
# Get these from your Cloudinary Dashboard

# Your cloud name (e.g., dg8ijpqow)
CLOUDINARY_CLOUD_NAME=dg8ijpqow

# API Key (from Cloudinary Dashboard → Settings → API Keys)
# Your API key here
CLOUDINARY_API_KEY=your_api_key

# API Secret (from Cloudinary Dashboard → Settings → API Keys)
# Your API secret here
CLOUDINARY_API_SECRET=your_api_secret

# ==========================================
# IMAGE BASE URLs
# ==========================================
# Hero images - use YOUR version number from Cloudinary
# Get from: Cloudinary → Libraries → Files → Click hero image → Version URL contains "v1777192151"
CLOUDINARY_HERO_BASE_URL=https://res.cloudinary.com/dg8ijpqow/image/upload/v1777192151/HeroPick/

# Item images
CLOUDINARY_ITEM_BASE_URL=https://res.cloudinary.com/dg8ijpqow/image/upload/v1777192151/Itemandspell/

# Voice lines (optional)
CLOUDINARY_VOICE_BASE_URL=https://res.cloudinary.com/dg8ijpqow/image/upload/v1777192151/Voicelines/

# Fonts (optional)
CLOUDINARY_FONT_BASE_URL=https://res.cloudinary.com/dg8ijpqow/image/upload/v1777192151/Font/

# App Password (for co-streamer access)
APP_PASSWORD=mlbbsepi